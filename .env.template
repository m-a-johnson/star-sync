# ── star-sync environment variables ──────────────────────────────────────────
# Copy the values below into your music_media stack .env file,
# or set them directly in the compose environment: block.

# Navidrome connection
STAR_SYNC_ND_USER=mark               # your Navidrome username
STAR_SYNC_ND_PASS=                   # your Navidrome password

# Lidarr connection
STAR_SYNC_LIDARR_API_KEY=            # Settings → General → Security → API Key

# Lidarr profile IDs
# To find these: GET http://lidarr.main.johnsoritti.com/api/v1/qualityprofile
#                GET http://lidarr.main.johnsoritti.com/api/v1/metadataprofile
STAR_SYNC_QUALITY_PROFILE_ID=1
STAR_SYNC_METADATA_PROFILE_ID=1

# How often to check for new starred songs (seconds)
# 300 = every 5 minutes
STAR_SYNC_POLL_INTERVAL=300

# Set to true to preview what would happen without touching Lidarr
STAR_SYNC_DRY_RUN=false

# If true, starring a song from your MAIN library (not Aurral flows) will
# also add that artist to Lidarr as unmonitored, if they aren't there already.
# If false (default), main library stars are silently skipped — they're already
# managed by Lidarr so there's nothing to do.
STAR_SYNC_PROCESS_MAIN_LIBRARY_STARS=false

# Log verbosity: DEBUG, INFO, WARNING, ERROR
STAR_SYNC_LOG_LEVEL=INFO

#Navidrome library ID to use for identifying starred songs. Use getMusicFolders to find your library IDs.
STAR_SYNC_NAVIDROME_FLOWS_LIBRARY_ID=3

STAR_SYNC_ALBUM_WAIT_TIMEOUT=120